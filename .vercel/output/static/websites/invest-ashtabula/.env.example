# Invest Ashtabula - Environment Variables

# This is primarily a static site, but these variables are available for future enhancements:

# Google Gemini API Key (optional - for AI chatbot feature)
# Get your API key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# API Base URL (if backend is added)
VITE_API_URL=http://localhost:3000

# Contact Form Endpoint (optional - for lead capture)
VITE_CONTACT_FORM_ENDPOINT=
