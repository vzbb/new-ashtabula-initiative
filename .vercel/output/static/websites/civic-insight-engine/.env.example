# Civic Insight Engine - Environment Variables

# Google Gemini API Key (required for AI meeting summarization)
# Get your API key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Set to 'true' to use mock data instead of API (for development)
VITE_USE_MOCK_DATA=false
